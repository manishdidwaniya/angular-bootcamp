# ─── Database ───
POSTGRES_USER=ajh_user
POSTGRES_PASSWORD=ajh_dev_pass
POSTGRES_DB=ai_job_hunter
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ajh_user:ajh_dev_pass@localhost:5432/ai_job_hunter

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ─── Live job providers and freshness ───
JOB_FRESHNESS_DAYS=7
JOB_SYNC_INTERVAL_MINUTES=30
JOB_SYNC_PAGES_PER_PROVIDER=2
SCHEDULER_ENABLED=true
ENABLE_LIVE_PROVIDERS=true
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in
THEMUSE_API_KEY=

# ─── JWT ───
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Notifications ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ─── AI ───
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# ─── App ───
ENVIRONMENT=development
BACKEND_PORT=8000
FRONTEND_PORT=4200
CORS_ORIGINS=["http://localhost:4200","http://localhost:3000"]
